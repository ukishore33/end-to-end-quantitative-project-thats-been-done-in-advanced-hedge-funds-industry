# Environment Configuration
# Copy this file to .env and fill in your values

# Data Source API Keys
YAHOO_FINANCE_API_KEY=
IEX_CLOUD_API_KEY=
POLYGON_API_KEY=

# Broker Integration (Optional)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # Paper trading URL

# Interactive Brokers (Optional)
IB_ACCOUNT=
IB_USERNAME=

# Database Configuration
DATABASE_URL=sqlite:///./hedge_fund.db
# Alternatively for PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/hedge_fund

# Notifications
SLACK_WEBHOOK_URL=
SENDGRID_API_KEY=
ALERT_EMAIL=your-email@example.com

# Trading Configuration
TRADING_MODE=paper  # Options: paper, live
INITIAL_CAPITAL=1000000
MAX_LEVERAGE=1.0
MAX_DAILY_LOSS=0.02  # 2% daily loss limit

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/hedge_fund.log

# Risk Management
MAX_POSITION_SIZE=0.05  # 5% per position
MAX_SECTOR_EXPOSURE=0.25  # 25% per sector
DAILY_VAR_LIMIT=0.02  # 2% daily Value-at-Risk

# Feature Flags
ENABLE_BACKTESTING=true
ENABLE_PAPER_TRADING=true
ENABLE_LIVE_TRADING=false
ENABLE_DASHBOARD=true
ENABLE_MONITORING=true

# Performance Tuning
NUM_WORKERS=4
CACHE_SIZE=1000
DATA_CACHE_DAYS=30

# Development
DEBUG=false
ENVIRONMENT=development  # Options: development, staging, production
